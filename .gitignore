# Never commit resume.sh, resume.txt, editor/OS/Python artifacts, or local
# Obsidian/agent state. Patterns use **/ so they match at every directory level.

**/resume.sh
**/resume.txt
**/.DS_Store
**/.claude
**/.claude/settings.local.json
**/.codex
**/.trash/
**/.obsidian/workspace.json
**/.obsidian/graph.json
**/.obsidian/plugins/*/data.json
**/*.swp
**/Thumbs.db
**/*.pyc
**/*.pyo
**/__pycache__/
